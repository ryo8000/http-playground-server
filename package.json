{
  "name": "http-playground-server",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/server.js",
  "repository": "https://github.com/ryo8000/http-playground-server.git",
  "author": "Ryo Hasegawa",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon",
    "test": "jest --coverage",
    "test:e2e": "newman run tests/e2e/e2e-test-collection.json -e tests/e2e/environment.json --reporters cli",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests"
  },
  "dependencies": {
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "express": "5.2.1",
    "pino": "10.3.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/cookie-parser": "1.4.10",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/jest": "30.0.0",
    "@types/node": "25.9.1",
    "@types/supertest": "7.2.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "jest": "30.4.2",
    "newman": "6.2.2",
    "nodemon": "3.1.14",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.3",
    "supertest": "7.2.2",
    "ts-jest": "29.4.11",
    "tsx": "4.22.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.0"
  },
  "resolutions": {
    "flatted": "3.4.2",
    "handlebars": "4.7.9",
    "jose": "4.15.5",
    "lodash": "4.18.0",
    "node-forge": "1.4.0",
    "qs": "6.14.2",
    "underscore": "1.13.8"
  }
}
